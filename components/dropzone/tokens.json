{
    "drop-zone-background-color-rgb": {
        "$schema": "https://opensource.adobe.com/spectrum-tokens/schemas/token-types/color-set.json",
        "sets": {
            "dark": {
                "$schema": "https://opensource.adobe.com/spectrum-tokens/schemas/token-types/alias.json",
                "note": "Replace with --spectrum-accent-color-900 when rgb value available",
                "value": "var(--spectrum-blue-900-rgb)"
            },
            "light": {
                "$schema": "https://opensource.adobe.com/spectrum-tokens/schemas/token-types/alias.json",
                "note": "Replace with --spectrum-accent-color-800 when rgb value available",
                "value": "var(--spectrum-blue-800-rgb)"
            }
        }
    }
}
